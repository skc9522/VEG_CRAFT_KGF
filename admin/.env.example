# Copy to `admin/.env.local` — same VITE_FIREBASE_* values as the root `.env.local`.

# Optional: customer menu base URL for QR codes (no trailing slash). If unset, QRs use
# https://<VITE_FIREBASE_PROJECT_ID>.web.app (e.g. veg-cafe → https://veg-cafe.web.app) so phone scans work
# even when the admin runs on localhost. Set this if your menu URL differs (custom domain, etc.).
VITE_CUSTOMER_APP_URL=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# Simple staff PIN (frontend only). Rebuild admin after changing.
VITE_ADMIN_PIN=
