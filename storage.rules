rules_version = '2';

// Firebase Console → Storage → Rules → Publish
// OR: firebase deploy --only storage
//
// Dev / trusted: anyone can read/write menu photos. Tighten before public launch.

service firebase.storage {
  match /b/{bucket}/o {
    match /menu_images/{menuId}/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
