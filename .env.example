# Copy this file to `.env.local` in this folder and fill in values from Firebase Console
# (Project settings → Your apps → Web app → firebaseConfig).
# Also copy the same lines to `admin/.env.local` for the kitchen admin app.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Google Analytics / GA4 in Firebase console)
# VITE_FIREBASE_MEASUREMENT_ID=

# Guest menu: table number only from scanned QR (?table=). Uncomment to allow typing table if QR is missing.
# VITE_ALLOW_MANUAL_TABLE=true
